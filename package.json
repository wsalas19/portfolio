    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.4.10",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.323.0",
    "motion": "^12.40.0",
    "next": "^15.1.0",
    "ogl": "^1.0.11",
